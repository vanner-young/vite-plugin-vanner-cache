{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": ["node_modules/**", "dist/**"],
  "printWidth": 120,
  "tabWidth": 4,
  "semi": true,
  "overrides": [
    {
      "files": ["*.json"],
      "options": {
        "tabWidth": 2,
        "semi": false
      }
    },
    {
      "files": ["*.css", "*.scss", "*.less"],
      "options": {
        "tabWidth": 2,
        "semi": false
      }
    }
  ]
}
