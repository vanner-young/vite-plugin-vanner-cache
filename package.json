{
  "name": "vite-plugin-vanner-cache",
  "version": "0.0.3",
  "description": "一款采用 sw 开发的 Vite 开发、生成缓存插件，可对后端响应慢的请求实现毫秒级缓存加载。其缓存时间窗口取决于接口的响应时间。",
  "license": "MIT",
  "main": "./dist/plugin.js",
  "types": "./dist/types/plugin",
  "repository": "https://github.com/vanner-young/vite-plugin-vanner-cache.git",
  "author": "vanneryoung@gmail.com <vanneryoung@gmail.com>",
  "keywords": [
    "cache",
    "fetch cache",
    "vite plugin"
  ],
  "files": [
    "dist",
    "package.json"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "format": "oxfmt",
    "lint": "oxlint && tsc -b",
    "format:check": "oxfmt --check",
    "build": "pnpm lint && pnpm format && rolldown -c",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "rolldown": "^1.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
